      "updated": 1779044196228,
      "link": null,
      "locked": false,
      "text": "Character\n{\n    name              = string,\n    portrait          = string,   -- sprite path\n    relationshipLevel = number,\n    encounters = {\n        {\n            day = number,\n            desire = {\n                primary   = \"success\" | \"love\" | \"wealth\" | \"stability\",\n                secondary = \"success\" | \"love\" | \"wealth\" | \"stability\",  -- or nil\n            },\n            ambiguityTolerance  = number,   -- 0 to 10\n            negativityTolerance = \"low\" | \"medium\" | \"high\",\n            dialogue            = { string },\n            outcome = {\n                positive = { minScore = number, relationshipDelta = number, dialogue = string },\n                neutral  = { minScore = number, relationshipDelta = number, dialogue = string },\n                negative = { relationshipDelta = number, dialogue = string },\n            }\n        }\n    }\n}",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Character\n{\n    name              = string,\n    portrait          = string,   -- sprite path\n    relationshipLevel = number,\n    encounters = {\n        {\n            day = number,\n            desire = {\n                primary   = \"success\" | \"love\" | \"wealth\" | \"stability\",\n                secondary = \"success\" | \"love\" | \"wealth\" | \"stability\",  -- or nil\n            },\n            ambiguityTolerance  = number,   -- 0 to 10\n            negativityTolerance = \"low\" | \"medium\" | \"high\",\n            dialogue            = { string },\n            outcome = {\n                positive = { minScore = number, relationshipDelta = number, dialogue = string },\n                neutral  = { minScore = number, relationshipDelta = number, dialogue = string },\n                negative = { relationshipDelta = number, dialogue = string },\n            }\n        }\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
